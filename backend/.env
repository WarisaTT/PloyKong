# ─── Server ───────────────────────────────────────────────
PORT=8082
ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8082,https://app.ploykong.com

# ─── Database ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=warisa2708
DB_NAME=ploykong

# ─── JWT ──────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change_this_to_a_very_long_random_secret_string_in_production_64_chars_minimum
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ─── Storage ──────────────────────────────────────────────
UPLOAD_DIR=./uploads
