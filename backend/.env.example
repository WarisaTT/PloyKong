# ─── Server ───────────────────────────────────────────────
PORT=3000
ENV=development
ALLOWED_ORIGINS=http://localhost:5173,https://app.ploykong.com

# ─── Database ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=ploykong
DB_PASSWORD=your_strong_password_here
DB_NAME=ploykong

# ─── JWT ──────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change_this_to_a_very_long_random_secret_string_in_production_64_chars_minimum
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ─── Storage ──────────────────────────────────────────────
UPLOAD_DIR=./uploads
CLOUDINARY_URL=

# S3 (AWS, DigitalOcean, MinIO)
S3_BUCKET=your-bucket-name
S3_REGION=ap-southeast-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_ENDPOINT= # Leave empty for AWS S3. Fill for DO Spaces/MinIO
